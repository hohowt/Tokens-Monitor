apiVersion: v1
kind: Secret
metadata:
  name: token-monitor-secrets
type: Opaque
stringData:
  DATABASE_URL: "postgresql+asyncpg://monitor:CHANGE_ME@postgres-service:5432/token_monitor"
  REDIS_URL: "redis://redis-service:6379/0"
  NEWAPI_BASE_URL: "http://new-api-service:3000"
  NEWAPI_ADMIN_TOKEN: "CHANGE_ME"
  ALERT_WEBHOOK_URL: ""
