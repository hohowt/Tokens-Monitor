# 后端环境变量模板 — 复制为 .env 后修改
DATABASE_URL=postgresql+asyncpg://monitor:ChangeMeInProduction!2026@db:5432/token_monitor
REDIS_URL=redis://redis:6379/0

# New API 网关配置（可选，如果同时使用 AI 网关）
NEWAPI_BASE_URL=
NEWAPI_ADMIN_TOKEN=

# 汇率
USD_TO_CNY=7.25

# 告警 Webhook（企微/钉钉/飞书，留空则不发告警）
ALERT_WEBHOOK_URL=

# 同步间隔（分钟）
SYNC_INTERVAL_MINUTES=10
